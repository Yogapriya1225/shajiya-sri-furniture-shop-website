# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.venv/
ENV/

# Environment variables (never commit real secrets)
.env
.env.local
.env.*.local

# Flask / instance
instance/
.webassets-cache

# Uploaded media (product/gallery images uploaded via admin panel)
uploads/

# Flask-Migrate is version controlled, but its cache/lock files are not
migrations/__pycache__/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Logs
*.log
