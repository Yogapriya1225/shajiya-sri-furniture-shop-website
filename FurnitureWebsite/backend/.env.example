# ---------------------------------------------------------------------------
# Backend environment variables
# Copy this file to ".env" for local development: cp .env.example .env
# On Render, set these under your Web Service -> Environment tab instead
# of committing a real .env file.
# ---------------------------------------------------------------------------

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
PORT=5000

# JWT (admin authentication)
JWT_SECRET_KEY=change-this-to-a-different-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12

# ---------------------------------------------------------------------------
# Database (MySQL)
# Option A: set discrete DB_* variables (used for local development)
# ---------------------------------------------------------------------------
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shajiya_sri_furniture

# Option B: OR set a single DATABASE_URL (used on Render / most managed DBs).
# When present, DATABASE_URL takes priority over the DB_* variables above.
# Example (PlanetScale / Railway / Aiven / Render MySQL add-on style):
# DATABASE_URL=mysql+pymysql://user:password@host:3306/shajiya_sri_furniture
DATABASE_URL=

# ---------------------------------------------------------------------------
# CORS - comma-separated list of frontend origins allowed to call this API.
# Add your local dev URL AND your deployed Vercel URL(s).
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,https://shajiya-sri-furniture.vercel.app

# File uploads (product/gallery images)
UPLOAD_FOLDER=uploads

# First admin account, used by the `flask seed-admin` CLI command
# (see app/utils/seed.py) to bootstrap the very first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
