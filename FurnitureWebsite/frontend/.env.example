# ---------------------------------------------------------------------------
# Frontend environment variables
# Copy this file to ".env" for local development and fill in real values.
# On Vercel, set these under Project Settings -> Environment Variables.
# All Vite env vars MUST be prefixed with VITE_ to be exposed to the client.
# ---------------------------------------------------------------------------

# Base URL of the Flask backend API (no trailing slash)
# Local:      http://localhost:5000/api
# Production: https://shajiya-sri-backend.onrender.com/api
# VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_BASE_URL=https://shajiya-sri-furniture-shop-website.onrender.com/api
# Public site URL (used for canonical links / SEO / sitemap generation)
VITE_SITE_URL=https://shajiya-sri-furniture-shop-website-vcbx-1yyganu7o.vercel.app
